---
import { Image, getImage } from 'astro:assets';
import { type Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import type { Photo } from '../data/photos';

interface Props {
  photo: Photo;
  lang: Lang;
  sizes?: string;
  loading?: 'lazy' | 'eager';
  variant?: 'photo' | 'plan';
}
const {
  photo,
  lang,
  sizes = '(max-width: 720px) 100vw, 33vw',
  loading = 'lazy',
  variant = 'photo',
} = Astro.props;
const t = useTranslations(lang);
const caption = t(photo.cap);

// Plantegninger vises i sin helhet (ikke beskåret) og trenger litt mer oppløsning
// for at romnavnene skal være lesbare.
const widths = variant === 'plan' ? [560, 900, 1280] : [400, 700, 1066];

// Full oppløsning til lightbox (klikk for større versjon)
const full = await getImage({
  src: photo.src,
  width: photo.src.width,
  format: 'webp',
});
---

<button
  type="button"
  class:list={['shot', variant === 'plan' && 'shot--plan']}
  data-full={full.src}
  data-caption={caption}
  aria-label={caption}
>
  <Image
    src={photo.src}
    alt={caption}
    widths={widths}
    sizes={sizes}
    loading={loading}
  />
  <span class="shot__cap">{caption}</span>
</button>
