---
import { Image, getImage } from 'astro:assets';
import { type Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import type { Photo } from '../data/photos';

interface Props {
  photo: Photo;
  lang: Lang;
  sizes?: string;
  loading?: 'lazy' | 'eager';
}
const { photo, lang, sizes = '(max-width: 720px) 100vw, 33vw', loading = 'lazy' } =
  Astro.props;
const t = useTranslations(lang);
const caption = t(photo.cap);

// Full oppløsning til lightbox (klikk for større versjon)
const full = await getImage({
  src: photo.src,
  width: photo.src.width,
  format: 'webp',
});
---

<button
  type="button"
  class="shot"
  data-full={full.src}
  data-caption={caption}
  aria-label={caption}
>
  <Image
    src={photo.src}
    alt={caption}
    widths={[400, 700, 1066]}
    sizes={sizes}
    loading={loading}
  />
  <span class="shot__cap">{caption}</span>
</button>
