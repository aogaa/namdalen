---
import { Image } from 'astro:assets';
import { type Lang } from '../i18n/ui';
import { useTranslations, localePath } from '../i18n/utils';
import Figure from './Figure.astro';
import {
  heroPhoto,
  propertyPhotos,
  fishingPhotos,
  areaPhotos,
  floorPlanPhotos,
} from '../data/photos';
import { linkGroups, resolveUrl } from '../data/links';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const base = localePath(lang);

const facts = [
  ['property.f.type', 'property.f.typeVal'],
  ['property.f.bedrooms', 'property.f.bedroomsVal'],
  ['property.f.area', 'property.f.areaVal'],
  ['property.f.matrikkel', 'property.f.matrikkelVal'],
  ['property.f.river', 'property.f.riverVal'],
  ['property.f.airport', 'property.f.airportVal'],
  ['property.f.location', 'property.f.locationVal'],
  ['property.f.price', 'property.f.priceVal'],
] as const;

const mapUrl = 'https://maps.app.goo.gl/N9xqx2y75C4ZEB648';

// Fisket: første bilde stort, resten i rad
const [fishingLead, ...fishingRest] = fishingPhotos;
// Området: første bilde stort, resten som årstider
const [areaLead, ...areaSeasons] = areaPhotos;
---

<!-- HERO -->
<section class="hero">
  <div class="hero__media">
    <Image
      src={heroPhoto}
      alt=""
      widths={[700, 1066]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
  </div>
  <div class="hero__scrim"></div>
  <div class="container hero__inner">
    <p class="eyebrow">{t('hero.eyebrow')}</p>
    <h1>{t('hero.title')}</h1>
    <p class="hero__subtitle">{t('hero.subtitle')}</p>
    <div class="hero__actions">
      <a class="btn btn--primary" href={`${base}/#property`}>{t('hero.cta')}</a>
      <a class="btn btn--ghost" href={`${base}/#fishing`}>{t('hero.cta2')}</a>
    </div>
  </div>
</section>

<!-- EIENDOMMEN -->
<section id="property" class="section">
  <div class="container">
    <div class="section__head">
      <h2>{t('property.title')}</h2>
      <p class="section__lead">{t('property.lead')}</p>
    </div>

    <div class="gallery">
      {
        propertyPhotos.map((photo, i) => (
          <Figure
            photo={photo}
            lang={lang}
            sizes={i === 0 ? '(max-width: 720px) 100vw, 66vw' : '(max-width: 720px) 100vw, 33vw'}
          />
        ))
      }
    </div>

    <h3 style="margin-top:2.5rem">{t('property.factsTitle')}</h3>
    <dl class="facts">
      {
        facts.map(([k, v]) => (
          <div>
            <dt>{t(k)}</dt>
            <dd>{t(v)}</dd>
          </div>
        ))
      }
    </dl>

    <h3 style="margin-top:2.5rem">{t('property.plansTitle')}</h3>
    <p class="section__lead">{t('property.plansLead')}</p>
    <div class="plans">
      {
        floorPlanPhotos.map((photo) => (
          <Figure
            photo={photo}
            lang={lang}
            variant="plan"
            sizes="(max-width: 720px) 100vw, 50vw"
          />
        ))
      }
    </div>
  </div>
</section>

<!-- FISKET -->
<section id="fishing" class="section section--alt">
  <div class="container">
    <div class="split">
      <div>
        <p class="eyebrow">{t('fishing.lead')}</p>
        <h2>{t('fishing.title')}</h2>
        <p>{t('fishing.p1')}</p>
        <p>{t('fishing.p2')}</p>
      </div>
      <Figure photo={fishingLead} lang={lang} sizes="(max-width: 820px) 100vw, 50vw" />
    </div>

    <div class="cards">
      <div class="card"><strong>≈ 100 km</strong>{t('fishing.factLength')}</div>
      <div class="card"><strong>★</strong>{t('fishing.factBig')}</div>
      <div class="card"><strong>⚓</strong>{t('fishing.factHarling')}</div>
    </div>

    <h3 style="margin-top:2.5rem">{t('fishing.galleryTitle')}</h3>
    <div class="gallery gallery--row">
      {fishingRest.map((photo) => <Figure photo={photo} lang={lang} sizes="(max-width: 720px) 100vw, 25vw" />)}
    </div>

    <p class="note">{t('fishing.disclaimer')}</p>
  </div>
</section>

<!-- OMRÅDET -->
<section id="area" class="section">
  <div class="container">
    <div class="split">
      <Figure photo={areaLead} lang={lang} sizes="(max-width: 820px) 100vw, 50vw" />
      <div>
        <p class="eyebrow">{t('area.lead')}</p>
        <h2>{t('area.title')}</h2>
        <p>{t('area.p1')}</p>
        <div class="callout">
          <strong>{t('area.flights')}</strong>
          <span>{t('area.total')}</span>
        </div>
        <h3 style="margin-top:1.5rem">{t('area.travelTitle')}</h3>
        <ul>
          <li>{t('area.travel1')}</li>
          <li>{t('area.travel3')}</li>
        </ul>
        <p>
          <a href={mapUrl} target="_blank" rel="noopener">{t('area.mapLink')} →</a>
        </p>
      </div>
    </div>

    <h3 style="margin-top:2.5rem">{t('area.seasonsTitle')}</h3>
    <div class="gallery gallery--row">
      {areaSeasons.map((photo) => <Figure photo={photo} lang={lang} sizes="(max-width: 720px) 100vw, 33vw" />)}
    </div>
  </div>
</section>

<!-- UTFORSK / RESSURSER -->
<section id="explore" class="section section--alt">
  <div class="container">
    <div class="section__head">
      <h2>{t('links.title')}</h2>
      <p class="section__lead">{t('links.lead')}</p>
    </div>
    <div class="linkgroups">
      {
        linkGroups.map((group) => (
          <div class="linkgroup">
            <h3>{t(group.titleKey)}</h3>
            <ul>
              {group.items.map((item) => (
                <li>
                  <a href={resolveUrl(item.url, lang)} target="_blank" rel="noopener">
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- KONTAKT -->
<section id="contact" class="section">
  <div class="container">
    <div class="section__head">
      <h2>{t('contact.title')}</h2>
      <p class="section__lead">{t('contact.lead')}</p>
      <p class="eyebrow" style="margin-top:1.25rem; font-weight:700">
        {t('contact.personLabel')} · {t('contact.person')}
      </p>
    </div>
    <div class="contact-grid">
      <div class="contact-card">
        <p class="label">{t('contact.emailLabel')}</p>
        <a href={`mailto:${t('contact.email')}`}>{t('contact.email')}</a>
      </div>
      <div class="contact-card">
        <p class="label">{t('contact.phoneLabel')}</p>
        <a href={`tel:${t('contact.phone').replace(/[^+\d]/g, '')}`}>{t('contact.phone')}</a>
      </div>
    </div>
  </div>
</section>
