---
import { languages, type Lang } from '../i18n/ui';
import { localePath } from '../i18n/utils';

interface Props {
  current: Lang;
}
const { current } = Astro.props;

const flagSrc: Record<Lang, string> = {
  no: '/flags/no.svg',
  en: '/flags/gb.svg',
  de: '/flags/de.svg',
  nl: '/flags/nl.svg',
};
---

<nav class="langpicker" aria-label="Språk / Language">
  {
    (Object.keys(languages) as Lang[]).map((lang) => (
      <a
        href={`${localePath(lang)}/`}
        hreflang={lang}
        aria-current={lang === current ? 'true' : 'false'}
        aria-label={languages[lang]}
        title={languages[lang]}
      >
        <img src={flagSrc[lang]} alt="" width="24" height="18" aria-hidden="true" />
      </a>
    ))
  }
</nav>
