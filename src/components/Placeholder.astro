---
// Midlertidig bildeplassholder. Byttes ut med astro:assets <Image> når ekte
// foto ligger i src/images/. Bygger uten bildefiler.
interface Props {
  label: string;
  ratio?: string; // f.eks. "16 / 9"
}
const { label, ratio = '4 / 3' } = Astro.props;
---

<div class="ph" style={`--ratio: ${ratio}`}>
  <span>{label}</span>
</div>
